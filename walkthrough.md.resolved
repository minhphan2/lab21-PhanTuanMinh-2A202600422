### 2.10 — Hoàn thành `tests/test_train.py` (10 TODOs)

```python
def _make_temp_data(tmp_path):
    rng = np.random.default_rng(0)
    n = 200
    X = rng.random((n, len(FEATURE_NAMES)))           # TODO 1
    y = rng.integers(0, 3, size=n)                      # TODO 2
    df = pd.DataFrame(X, columns=FEATURE_NAMES)         # TODO 3
    df["target"] = y
    train_path = str(tmp_path / "train.csv")            # TODO 4
    eval_path = str(tmp_path / "eval.csv")
    df.iloc[:160].to_csv(train_path, index=False)
    df.iloc[160:].to_csv(eval_path, index=False)
    return train_path, eval_path                        # TODO 5

def test_train_returns_float(tmp_path):
    train_path, eval_path = _make_temp_data(tmp_path)
    acc = train({"n_estimators": 10, "max_depth": 3},   # TODO 6
                data_path=train_path, eval_path=eval_path)
    assert isinstance(acc, float)                        # TODO 7
    assert 0.0 <= acc <= 1.0

def test_metrics_file_created(tmp_path):
    # ... (đã có sẵn phần gọi train)
    assert os.path.exists("outputs/metrics.json")        # TODO 8
    with open("outputs/metrics.json") as f:              # TODO 9
        metrics = json.load(f)
    assert "accuracy" in metrics
    assert "f1_score" in metrics

def test_model_file_created(tmp_path):
    # ...
    assert os.path.exists("models/model.pkl")            # TODO 10
```

**Lý do**: Tests chạy trên dữ liệu giả (random) → không cần cloud access. CI/CD chạy test trước khi train → nếu code lỗi, dừng ngay, tiết kiệm chi phí cloud.

**Học được**: Unit testing cho ML — test hàm train trả về đúng kiểu, tạo đúng file output. `tmp_path` của pytest tự cleanup.

